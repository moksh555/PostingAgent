# ---------------------------------------------------------------------------
# Secrets / environment
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
configurations/.env
configurations/.env.*
!configurations/.env.example

# ---------------------------------------------------------------------------
# Python bytecode / caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# uv / pip / poetry
# ---------------------------------------------------------------------------
# Keep uv.lock committed (reproducible installs). Ignore uv's local cache only.
.uv/
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ---------------------------------------------------------------------------
# Type checkers / linters
# ---------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ---------------------------------------------------------------------------
# Build artefacts
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
MANIFEST

# ---------------------------------------------------------------------------
# IDE / editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ---------------------------------------------------------------------------
# OS noise
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Logs
